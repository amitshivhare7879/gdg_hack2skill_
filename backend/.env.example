GEMINI_API_KEY=
FRONTEND_ORIGIN=http://localhost:3000
SIMILARITY_THRESHOLD=0.82
DATABASE_URL=sqlite:///./janvikas.db

# Backup generation provider — any OpenAI-compatible chat API (default: Groq,
# Llama 3.3 70B, free tier). Optional — leave LLM_API_KEY blank to disable.
# Used only when a Gemini generation call fails. Chat-only (no embeddings).
# LLM_MODEL accepts a LiteLLM-style "provider/" prefix; it is stripped for the
# raw call. GROQ_API_KEY is also accepted as the key.
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/llama-3.3-70b-versatile
